python -c "
from google.cloud import bigquery
client = bigquery.Client(project='cloud-data-project-492514')

ddl_events = '''
CREATE TABLE IF NOT EXISTS staging.events (
  id INT64,
  user_id INT64,
  sequence_number INT64,
  session_id STRING,
  ip_address STRING,
  city STRING,
  state STRING,
  postal_code STRING,
  browser STRING,
  traffic_source STRING,
  uri STRING,
  event_type STRING,
  created_at TIMESTAMP,
  cdc_timestamp INT64,
  cdc_operation STRING
)
'''
ddl_orders = '''
CREATE TABLE IF NOT EXISTS staging.orders (
  order_id INT64,
  user_id INT64,
  status STRING,
  gender STRING,
  created_at TIMESTAMP,
  returned_at TIMESTAMP,
  shipped_at TIMESTAMP,
  delivered_at TIMESTAMP,
  num_of_item INT64,
  cdc_timestamp INT64,
  cdc_operation STRING
)
'''

client.query(ddl_events).result()
client.query(ddl_orders).result()
print('Created tables!')
"

bq mk --dataset --location=asia-southeast1 cloud-data-project-492514:thelook_clickstream