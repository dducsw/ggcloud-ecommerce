  create or replace view `cloud-data-project-492514`.`thelook_staging`.`stg_orders`
  OPTIONS()
  as 

with orders_base as (
    select
        cast(order_id as int64) as order_id,
        cast(user_id as int64) as user_id,
        coalesce(cast(status as string), 'Unknown') as status,
        coalesce(cast(gender as string), 'Unknown') as gender,
        coalesce(case
    when created_at is null then null
    -- Chuỗi số nguyên (epoch ms hoặc μs từ Debezium/CDC) → convert theo độ dài
    when regexp_contains(cast(created_at as string), r'^\d+$') then
        case
            when length(cast(created_at as string)) >= 16
                then timestamp_micros(safe_cast(cast(created_at as string) as int64))
            when length(cast(created_at as string)) >= 13
                then timestamp_millis(safe_cast(cast(created_at as string) as int64))
            else timestamp_seconds(safe_cast(cast(created_at as string) as int64))
        end
    -- TIMESTAMP hoặc ISO string (Parquet external table) → safe_cast qua string
    else safe_cast(cast(created_at as string) as timestamp)
end, case
    when cdc_timestamp is null then null
    -- Chuỗi số nguyên (epoch ms hoặc μs từ Debezium/CDC) → convert theo độ dài
    when regexp_contains(cast(cdc_timestamp as string), r'^\d+$') then
        case
            when length(cast(cdc_timestamp as string)) >= 16
                then timestamp_micros(safe_cast(cast(cdc_timestamp as string) as int64))
            when length(cast(cdc_timestamp as string)) >= 13
                then timestamp_millis(safe_cast(cast(cdc_timestamp as string) as int64))
            else timestamp_seconds(safe_cast(cast(cdc_timestamp as string) as int64))
        end
    -- TIMESTAMP hoặc ISO string (Parquet external table) → safe_cast qua string
    else safe_cast(cast(cdc_timestamp as string) as timestamp)
end) as created_at,
        case
    when shipped_at is null then null
    -- Chuỗi số nguyên (epoch ms hoặc μs từ Debezium/CDC) → convert theo độ dài
    when regexp_contains(cast(shipped_at as string), r'^\d+$') then
        case
            when length(cast(shipped_at as string)) >= 16
                then timestamp_micros(safe_cast(cast(shipped_at as string) as int64))
            when length(cast(shipped_at as string)) >= 13
                then timestamp_millis(safe_cast(cast(shipped_at as string) as int64))
            else timestamp_seconds(safe_cast(cast(shipped_at as string) as int64))
        end
    -- TIMESTAMP hoặc ISO string (Parquet external table) → safe_cast qua string
    else safe_cast(cast(shipped_at as string) as timestamp)
end as shipped_at,
        case
    when delivered_at is null then null
    -- Chuỗi số nguyên (epoch ms hoặc μs từ Debezium/CDC) → convert theo độ dài
    when regexp_contains(cast(delivered_at as string), r'^\d+$') then
        case
            when length(cast(delivered_at as string)) >= 16
                then timestamp_micros(safe_cast(cast(delivered_at as string) as int64))
            when length(cast(delivered_at as string)) >= 13
                then timestamp_millis(safe_cast(cast(delivered_at as string) as int64))
            else timestamp_seconds(safe_cast(cast(delivered_at as string) as int64))
        end
    -- TIMESTAMP hoặc ISO string (Parquet external table) → safe_cast qua string
    else safe_cast(cast(delivered_at as string) as timestamp)
end as delivered_at,
        case
    when returned_at is null then null
    -- Chuỗi số nguyên (epoch ms hoặc μs từ Debezium/CDC) → convert theo độ dài
    when regexp_contains(cast(returned_at as string), r'^\d+$') then
        case
            when length(cast(returned_at as string)) >= 16
                then timestamp_micros(safe_cast(cast(returned_at as string) as int64))
            when length(cast(returned_at as string)) >= 13
                then timestamp_millis(safe_cast(cast(returned_at as string) as int64))
            else timestamp_seconds(safe_cast(cast(returned_at as string) as int64))
        end
    -- TIMESTAMP hoặc ISO string (Parquet external table) → safe_cast qua string
    else safe_cast(cast(returned_at as string) as timestamp)
end as returned_at,
        cast(num_of_item as int64) as num_of_item,
        -- CDC metadata: dùng để dedup và incremental
        cast(cdc_timestamp as int64) as cdc_timestamp,
        cast(cdc_operation as string) as cdc_operation
    from `cloud-data-project-492514`.`thelook_staging`.`orders`
        where cast(order_id as int64) is not null
      and cast(user_id as int64) is not null
      and cast(num_of_item as int64) >= 0
      -- Bỏ qua hard delete CDC events
      and coalesce(cast(cdc_operation as string), 'c') != 'd'
),
latest_orders as (
    select
        *,
        row_number() over (
            partition by order_id
            -- Dùng cdc_timestamp: thời điểm CDC event, KHÔNG phải business created_at
            -- Đảm bảo chọn đúng version mới nhất khi có update (status, shipped_at...)
            order by cdc_timestamp desc
        ) as rn
    from orders_base
)
select
    order_id,
    user_id,
    status,
    gender,
    created_at,
    shipped_at,
    delivered_at,
    returned_at,
    num_of_item,
    cdc_timestamp,
    cdc_operation
from latest_orders
where rn = 1;


