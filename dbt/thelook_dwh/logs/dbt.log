    )
 from `cloud-data-project-492514`.`thelook_datawarehouse`.`agg_user_stats`)
    

    union distinct

    -- (2) Users có đơn hàng mới hoặc được cập nhật
    select user_id
    from `cloud-data-project-492514`.`thelook_datawarehouse`.`fact_orders`
    
    where source_updated_at >= (select 
    timestamp_sub(
        coalesce(max(source_updated_at), timestamp('1970-01-01')),
        interval 3 day
    )
 from `cloud-data-project-492514`.`thelook_datawarehouse`.`agg_user_stats`)
    
)

select
    du.user_id,
    min(fo.created_at)                      as first_purchase_date,
    max(fo.created_at)                      as latest_purchase_date,
    count(distinct fo.order_id)             as total_orders,
    coalesce(sum(fo.total_revenue), 0)      as lifetime_value,
    case
        when count(distinct fo.order_id) = 0 then 'Potential'
        when count(distinct fo.order_id) = 1 then 'New'
        else 'Returning'
    end                                     as customer_status,
    max(coalesce(fo.source_updated_at, du.source_updated_at)) as source_updated_at,
    current_timestamp()                     as dwh_updated_at
from `cloud-data-project-492514`.`thelook_datawarehouse`.`dim_users` du
inner join impacted_users iu
    on du.user_id = iu.user_id
left join `cloud-data-project-492514`.`thelook_datawarehouse`.`fact_orders` fo
    on du.user_id = fo.user_id
group by du.user_id
        ) as DBT_INTERNAL_SOURCE
        on ((DBT_INTERNAL_SOURCE.user_id = DBT_INTERNAL_DEST.user_id))

    
    when matched then update set
        `user_id` = DBT_INTERNAL_SOURCE.`user_id`,`first_purchase_date` = DBT_INTERNAL_SOURCE.`first_purchase_date`,`latest_purchase_date` = DBT_INTERNAL_SOURCE.`latest_purchase_date`,`total_orders` = DBT_INTERNAL_SOURCE.`total_orders`,`lifetime_value` = DBT_INTERNAL_SOURCE.`lifetime_value`,`customer_status` = DBT_INTERNAL_SOURCE.`customer_status`,`source_updated_at` = DBT_INTERNAL_SOURCE.`source_updated_at`,`dwh_updated_at` = DBT_INTERNAL_SOURCE.`dwh_updated_at`
    

    when not matched then insert
        (`user_id`, `first_purchase_date`, `latest_purchase_date`, `total_orders`, `lifetime_value`, `customer_status`, `source_updated_at`, `dwh_updated_at`)
    values
        (`user_id`, `first_purchase_date`, `latest_purchase_date`, `total_orders`, `lifetime_value`, `customer_status`, `source_updated_at`, `dwh_updated_at`)


    
