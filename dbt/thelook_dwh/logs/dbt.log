end as returned_at,
        cast(num_of_item as int64) as num_of_item,
        -- CDC metadata: d├╣ng ─æß╗ā dedup v├Ā incremental
        cast(cdc_timestamp as int64) as cdc_timestamp,
        cast(cdc_operation as string) as cdc_operation
    from `cloud-data-project-492514`.`thelook_staging`.`orders`
        where cast(order_id as int64) is not null
      and cast(user_id as int64) is not null
      and cast(num_of_item as int64) >= 0
      -- Bß╗Å qua hard delete CDC events
      and coalesce(cast(cdc_operation as string), 'c') != 'd'
),
latest_orders as (
    select
        *,
        row_number() over (
            partition by order_id
            -- D├╣ng cdc_timestamp: thß╗Øi ─æiß╗ām CDC event, KH├öNG phß║Żi business created_at
            -- ─Éß║Żm bß║Żo chß╗Źn ─æ├║ng version mß╗øi nhß║źt khi c├│ update (status, shipped_at...)
            order by cdc_timestamp desc
        ) as rn
    from orders_base
)
select
    order_id,
    user_id,
    status,
    gender,
    created_at,
    shipped_at,
    delivered_at,
    returned_at,
    num_of_item,
    cdc_timestamp,
    cdc_operation
from latest_orders
where rn = 1;


