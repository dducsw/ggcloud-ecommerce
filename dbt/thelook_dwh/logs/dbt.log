    when not matched then insert
        (`date`, `revenue`, `cost`, `margin`, `orders`, `total_users`, `total_sessions`, `checkout_events`, `cvr`)
    values
        (`date`, `revenue`, `cost`, `margin`, `orders`, `total_users`, `total_sessions`, `checkout_events`, `cvr`)


    
